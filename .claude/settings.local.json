      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); [print\\(t['path']\\) for t in d.get\\('tree',[]\\) if t['type']=='blob']\")",
      "Bash(curl -sL \"https://raw.githubusercontent.com/multi-agent-systems-failure-taxonomy/MAST/main/taxonomy_definitions_examples/definitions.txt\" -o definitions.txt)",
      "Bash(python3 -c \"import mastlint; print\\('installed at', mastlint.__file__\\)\")",
      "Bash(python3 -c \"import pytest, pydantic, yaml; print\\('pytest', pytest.__version__, 'pydantic', pydantic.__version__\\)\")",
      "Bash(python3 -m pip show mastlint)",
      "Skill(claude-api)",
      "Skill(claude-api:*)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(python3 -c \"import json; d=json.load\\(open\\('.claude/settings.local.json'\\)\\); print\\('valid JSON; env =', d.get\\('env'\\)\\)\")",
      "Bash(python3 adjudicate.py)",
      "Bash(python3 evals/adjudicate.py)"
    ]
  }
}
