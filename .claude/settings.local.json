  "env": {
    "ECC_GATEGUARD": "off"
  },
  "permissions": {
    "allow": [
      "Skill(plan-eng-review)",
      "Skill(plan-eng-review:*)",
      "WebFetch(domain:arxiv.org)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:huggingface.co)",
      "Bash(curl -sIL \"https://huggingface.co/datasets/mcemri/MAD/resolve/main/MAD_human_labelled_dataset.json\")",
      "Bash(curl -sL \"https://huggingface.co/datasets/mcemri/MAD/resolve/main/MAD_human_labelled_dataset.json\" -o mad_human.json)",
      "Bash(python3 -)",
